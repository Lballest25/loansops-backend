{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "user_name":      { "type": "string" },
        "identification": { "type": "string" },
        "role":           { "type": "string", "enum": ["ADMIN", "ANALYST", "CLIENT"] },
        "is_active":      { "type": "integer", "enum": [0, 1] }
    },
    "minProperties": 1,
    "additionalProperties": false
}
